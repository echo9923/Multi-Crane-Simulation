{
  "name": "multi-crane-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "e2e": "playwright test",
    "desktop": "electron electron/main.cjs",
    "desktop:dev": "electron electron/dev.cjs",
    "desktop:pack": "npm run build && electron-builder --win --config.win.signAndEditExecutable=false --config.win.signExecutable=false --dir",
    "desktop:dist": "npm run build && electron-builder --win --config.win.signAndEditExecutable=false --config.win.signExecutable=false"
  },
  "build": {
    "appId": "com.multicrane.workbench",
    "productName": "Multi Crane Workbench",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "electron/**",
      "package.json",
      "!**/*.map",
      "!**/*.test.*",
      "!tests/**",
      "!src/**"
    ],
    "extraResources": [
      {
        "from": "../backend",
        "to": "project/backend",
        "filter": [
          "**/*",
          "!**/.env*",
          "!**/.claude/**",
          "!**/.worktrees/**",
          "!**/runs/**",
          "!**/__pycache__/**",
          "!**/*.pyc",
          "!**/.pytest_cache/**",
          "!**/tests/**",
          "!**/*.pem",
          "!**/*.p12",
          "!**/*.key",
          "!**/*token*.json",
          "!**/*credentials*.json"
        ]
      },
      {
        "from": "../configs",
        "to": "project/configs",
        "filter": [
          "**/*",
          "!**/.env*",
          "!**/.claude/**",
          "!**/.worktrees/**",
          "!**/runs/**",
          "!**/__pycache__/**",
          "!**/*.pyc",
          "!**/.pytest_cache/**",
          "!**/*.pem",
          "!**/*.p12",
          "!**/*.key",
          "!**/*token*.json",
          "!**/*credentials*.json"
        ]
      },
      {
        "from": "../.venv",
        "to": ".venv",
        "filter": [
          "**/*",
          "!**/.env*",
          "!**/.claude/**",
          "!**/.worktrees/**",
          "!**/runs/**",
          "!**/__pycache__/**",
          "!**/*.pyc",
          "!**/.pytest_cache/**",
          "!**/*.p12",
          "!**/*.key",
          "!**/*token*.json",
          "!**/*credentials*.json",
          "**/certifi/cacert.pem"
        ]
      },
      {
        "from": "../pyproject.toml",
        "to": "project/pyproject.toml"
      }
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "extendInfo": {
        "LSEnvironment": {
          "ELECTRON_RUN_AS_NODE": ""
        }
      },
      "target": [
        "dir",
        "dmg"
      ]
    },
    "win": {
      "target": [
        "dir"
      ],
      "signAndEditExecutable": false,
      "signExecutable": false
    }
  },
  "dependencies": {
    "fflate": "^0.8.2",
    "js-yaml": "^4.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2",
    "three": "^0.169.0",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@testing-library/react": "^16.0.1",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.7.4",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@types/three": "^0.169.0",
    "@vitejs/plugin-react": "^4.3.2",
    "autoprefixer": "^10.4.20",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.3",
    "jsdom": "^25.0.1",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.6.2",
    "vite": "^5.4.8",
    "vitest": "^2.1.2"
  }
}
